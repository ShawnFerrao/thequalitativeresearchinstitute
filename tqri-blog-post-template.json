{
  "version": "0.4",
  "title": "TQRI Blog Post Template",
  "type": "single-post",
  "content": [

    {
      "id": "sec-feat-img",
      "elType": "section",
      "isInner": false,
      "settings": {
        "layout": "full_width",
        "gap": "no",
        "height": "default",
        "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true },
        "margin": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true }
      },
      "elements": [
        {
          "id": "col-feat-img",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "_inline_size": null,
            "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true }
          },
          "elements": [
            {
              "id": "wgt-feat-img",
              "elType": "widget",
              "widgetType": "theme-post-featured-image",
              "settings": {
                "image_size": "full",
                "align": "center",
                "width": { "unit": "%", "size": 100, "sizes": [] },
                "height": { "unit": "px", "size": 480, "sizes": [] },
                "object-fit": "cover",
                "height_mobile": { "unit": "px", "size": 260, "sizes": [] },
                "_padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true }
              },
              "elements": []
            }
          ]
        }
      ]
    },

    {
      "id": "sec-header",
      "elType": "section",
      "isInner": false,
      "settings": {
        "layout": "boxed",
        "content_width": { "unit": "px", "size": 800, "sizes": [] },
        "background_background": "classic",
        "background_color": "#fdfcfa",
        "padding": { "unit": "px", "top": "50", "right": "20", "bottom": "10", "left": "20", "isLinked": false },
        "padding_mobile": { "unit": "px", "top": "32", "right": "20", "bottom": "10", "left": "20", "isLinked": false }
      },
      "elements": [
        {
          "id": "col-header",
          "elType": "column",
          "settings": { "_column_size": 100, "_inline_size": null },
          "elements": [

            {
              "id": "wgt-post-info",
              "elType": "widget",
              "widgetType": "post-info",
              "settings": {
                "icon_list": [
                  {
                    "_id": "pi-cat",
                    "type": "terms",
                    "custom_label": "",
                    "icon": { "value": "", "library": "" },
                    "taxonomy": "category"
                  },
                  {
                    "_id": "pi-date",
                    "type": "date",
                    "custom_label": "",
                    "icon": { "value": "", "library": "" },
                    "date_format": "default",
                    "custom_date_format": ""
                  },
                  {
                    "_id": "pi-author",
                    "type": "author",
                    "custom_label": "",
                    "icon": { "value": "", "library": "" }
                  }
                ],
                "text_color": "#6b7280",
                "links_color": "#c8873b",
                "space_between": { "unit": "px", "size": 20, "sizes": [] },
                "typography_typography": "custom",
                "typography_font_family": "Poppins",
                "typography_font_size": { "unit": "px", "size": 11, "sizes": [] },
                "typography_font_weight": "500",
                "typography_text_transform": "uppercase",
                "typography_letter_spacing": { "unit": "px", "size": 1.5, "sizes": [] },
                "_margin": { "unit": "px", "top": "0", "right": "0", "bottom": "18", "left": "0", "isLinked": false }
              },
              "elements": []
            },

            {
              "id": "wgt-post-title",
              "elType": "widget",
              "widgetType": "theme-post-title",
              "settings": {
                "header_size": "h1",
                "title_color": "#1a2744",
                "typography_typography": "custom",
                "typography_font_family": "Poppins",
                "typography_font_size": { "unit": "px", "size": 42, "sizes": [] },
                "typography_font_size_tablet": { "unit": "px", "size": 34, "sizes": [] },
                "typography_font_size_mobile": { "unit": "px", "size": 26, "sizes": [] },
                "typography_font_weight": "600",
                "typography_line_height": { "unit": "em", "size": 1.2, "sizes": [] },
                "_margin": { "unit": "px", "top": "0", "right": "0", "bottom": "20", "left": "0", "isLinked": false }
              },
              "elements": []
            },

            {
              "id": "wgt-post-excerpt",
              "elType": "widget",
              "widgetType": "theme-post-excerpt",
              "settings": {
                "text_color": "#6b7280",
                "typography_typography": "custom",
                "typography_font_family": "Poppins",
                "typography_font_size": { "unit": "px", "size": 18, "sizes": [] },
                "typography_font_size_mobile": { "unit": "px", "size": 16, "sizes": [] },
                "typography_font_weight": "300",
                "typography_font_style": "italic",
                "typography_line_height": { "unit": "em", "size": 1.75, "sizes": [] },
                "_margin": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false }
              },
              "elements": []
            }

          ]
        }
      ]
    },

    {
      "id": "sec-divider",
      "elType": "section",
      "isInner": false,
      "settings": {
        "layout": "boxed",
        "content_width": { "unit": "px", "size": 800, "sizes": [] },
        "background_background": "classic",
        "background_color": "#fdfcfa",
        "padding": { "unit": "px", "top": "30", "right": "20", "bottom": "0", "left": "20", "isLinked": false }
      },
      "elements": [
        {
          "id": "col-divider",
          "elType": "column",
          "settings": { "_column_size": 100, "_inline_size": null },
          "elements": [
            {
              "id": "wgt-divider",
              "elType": "widget",
              "widgetType": "divider",
              "settings": {
                "color": "#e2e8f0",
                "weight": { "unit": "px", "size": 1, "sizes": [] },
                "width": { "unit": "%", "size": 100, "sizes": [] },
                "gap": { "unit": "px", "size": 0, "sizes": [] },
                "style": "solid"
              },
              "elements": []
            }
          ]
        }
      ]
    },

    {
      "id": "sec-content",
      "elType": "section",
      "isInner": false,
      "settings": {
        "layout": "boxed",
        "content_width": { "unit": "px", "size": 750, "sizes": [] },
        "background_background": "classic",
        "background_color": "#fdfcfa",
        "padding": { "unit": "px", "top": "50", "right": "20", "bottom": "80", "left": "20", "isLinked": false },
        "padding_mobile": { "unit": "px", "top": "36", "right": "20", "bottom": "60", "left": "20", "isLinked": false }
      },
      "elements": [
        {
          "id": "col-content",
          "elType": "column",
          "settings": { "_column_size": 100, "_inline_size": null },
          "elements": [
            {
              "id": "wgt-post-content",
              "elType": "widget",
              "widgetType": "theme-post-content",
              "settings": {
                "color": "#2a2a2a",
                "typography_typography": "custom",
                "typography_font_family": "Poppins",
                "typography_font_size": { "unit": "px", "size": 17, "sizes": [] },
                "typography_font_size_mobile": { "unit": "px", "size": 15, "sizes": [] },
                "typography_font_weight": "300",
                "typography_line_height": { "unit": "em", "size": 1.9, "sizes": [] }
              },
              "elements": []
            }
          ]
        }
      ]
    },

    {
      "id": "sec-nav",
      "elType": "section",
      "isInner": false,
      "settings": {
        "layout": "boxed",
        "content_width": { "unit": "px", "size": 750, "sizes": [] },
        "background_background": "classic",
        "background_color": "#f8f5f0",
        "border_top_width": { "unit": "px", "top": "1", "right": "0", "bottom": "0", "left": "0", "isLinked": false },
        "border_color": "#e2e8f0",
        "padding": { "unit": "px", "top": "36", "right": "20", "bottom": "36", "left": "20", "isLinked": false }
      },
      "elements": [
        {
          "id": "col-nav",
          "elType": "column",
          "settings": { "_column_size": 100, "_inline_size": null },
          "elements": [
            {
              "id": "wgt-post-nav",
              "elType": "widget",
              "widgetType": "post-navigation",
              "settings": {
                "show_label": "yes",
                "prev_label": "← Previous Post",
                "next_label": "Next Post →",
                "link_full_post": "no",
                "prev_next_align": "space-between",
                "title_color": "#1a2744",
                "arrow_color": "#c8873b",
                "label_color": "#6b7280",
                "typography_typography": "custom",
                "typography_font_family": "Poppins",
                "typography_font_size": { "unit": "px", "size": 13, "sizes": [] },
                "typography_font_weight": "500",
                "typography_text_transform": "uppercase",
                "typography_letter_spacing": { "unit": "px", "size": 1, "sizes": [] }
              },
              "elements": []
            }
          ]
        }
      ]
    }

  ],
  "page_settings": {
    "post_status": "publish"
  }
}
